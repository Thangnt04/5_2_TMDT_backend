#Config environment
CI_ENV=development

# Config DB
DB_HOSTNAME=mariadb
DB_USERNAME=root
DB_PASSWORD=123456
DB_DATABASE=webquanao
DB_DRIVER=mysqli
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Config send email
MAIL_USERNAME=YOUR_EMAIL  
MAIL_PASSWORD=YOUR_PASSWORD

# Config jwt
JWT_EXPIRE=300 # 5 minutes

#reCAPTCHA google v2 key (xác thực recaptcha)
# create api key at (khi đã có tên miền chuẩn): https://www.google.com/recaptcha/admin/create
# nếu cần tạo key để chạy test local cần khai báo tên miền trong google cloud console: https://console.cloud.google.com/projectselector2/security/recaptcha?pli=1&inv=1&invt=AbsHIg&supportedpurview=project
PUBLIC_KEY=YOUR_KEY
PRIVATE_KEY=YOUR_KEY

# VNPay payment key (thanh toán bằng vnpay)
# Đăng kí tại VNPAY sanbox: https://sandbox.vnpayment.vn/devreg/ 
# Tên website đặt là: bb8a-59-153-220-86.ngrok-free.app
VNPAY_TMNCODE=W6UA3B3I
VNPAY_HASHSECRET=V01HFKTF07GOHSJFQF9OWMUGUOXX791A
# URL callback phải là domain public và đã khai báo trong VNPAY sandbox (không dùng localhost)
# ví dụ: https://<your-ngrok-subdomain>.ngrok-free.app/vnpay/callback
VNPAY_RETURN_URL=https://tiny-lizards-spend.loca.lt/vnpay/callback
# để trống sẽ cho user chọn phương thức; đặt VNPAYQR nếu muốn ưu tiên QR
VNPAY_BANKCODE=

#openroute service (tính phí ship dựa vào khoảng cách)
#Link: https://account.heigit.org/manage/key
OPENROUTE_SERVICE=YOUR_KEY

#google apiclient (đăng nhập bằng google) 
# link: https://console.cloud.google.com/
CLIENT_ID=YOUR_KEY
CLIENT_SECRET=YOUR_KEY

# Mã GA4 property
# link: https://analytics.google.com/
# cài đặt package: composer require google/analytics-data:^0.9.0 --with-all-dependencies
#p/s: để dùng được phải tạo service account trong google console, lấy key json ra, nhập email vào phần khai báo 
# trong google analytic... (nói chung là phức tạp)
GA4_PROPERTY=YOUR_KEY